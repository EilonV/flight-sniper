# Travelpayouts / Aviasales Data API
# 1. Sign up at https://www.travelpayouts.com and join the "Aviasales" program.
# 2. Copy your API token from the dashboard (Developers -> API / tokens).
# 3. Copy your affiliate "marker" (your partner ID) — used to build booking links.

# API token for the Data API (sent as the `token` query param)
TP_TOKEN=your_travelpayouts_api_token_here

# Your affiliate marker / partner id (appended to Aviasales booking links)
TP_MARKER=your_marker_here

# Currency for prices (iso code, lowercase). ils = Israeli Shekel.
CURRENCY=ils

# Optional: comma-separated origin airport/city IATA codes to scan from.
# Defaults to TLV. You can add more, e.g. "TLV,ETM".
ORIGINS=TLV
